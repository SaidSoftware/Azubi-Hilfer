    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyName>AzubiHilfer</AssemblyName>
    <RootNamespace>AzubiHilfer</RootNamespace>

  </PropertyGroup>

  <ItemGroup>
