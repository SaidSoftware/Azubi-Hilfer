<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brand Colors -->
    <Color x:Key="PrimaryColor">#1E3A5F</Color>
    <Color x:Key="PrimaryLightColor">#2E5090</Color>
    <Color x:Key="AccentColor">#F0A500</Color>
    <Color x:Key="AccentLightColor">#FFD166</Color>
    <Color x:Key="SidebarBgColor">#0F2341</Color>
    <Color x:Key="SidebarHoverColor">#1A3460</Color>
    <Color x:Key="SidebarSelectedColor">#F0A500</Color>
    <Color x:Key="ContentBgColor">#F5F7FA</Color>
    <Color x:Key="CardBgColor">#FFFFFF</Color>
    <Color x:Key="TextPrimaryColor">#1A1A2E</Color>
    <Color x:Key="TextSecondaryColor">#6B7280</Color>
    <Color x:Key="CodeBgColor">#1E1E2E</Color>
    <Color x:Key="BorderColor">#E5E7EB</Color>
    <Color x:Key="FIGroupColor">#3B82F6</Color>
    <Color x:Key="KDMGroupColor">#10B981</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}"/>
    <SolidColorBrush x:Key="SidebarBgBrush" Color="{StaticResource SidebarBgColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="SidebarSelectedBrush" Color="{StaticResource SidebarSelectedColor}"/>
    <SolidColorBrush x:Key="ContentBgBrush" Color="{StaticResource ContentBgColor}"/>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="CodeBgBrush" Color="{StaticResource CodeBgColor}"/>
    <SolidColorBrush x:Key="BorderBrush2" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="FIGroupBrush" Color="{StaticResource FIGroupColor}"/>
    <SolidColorBrush x:Key="KDMGroupBrush" Color="{StaticResource KDMGroupColor}"/>

</ResourceDictionary>
